# --- Meta / Instagram app ---
# From the Meta app dashboard (see docs/SETUP-META.md)
META_APP_ID=
META_APP_SECRET=
# Any random string you choose; must match what you enter in the webhook config
META_VERIFY_TOKEN=
# Instagram Professional account id (numeric)
IG_USER_ID=
# Graph API version you verified against the live docs, e.g. v23.0
META_API_VERSION=v23.0

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron protection ---
# Random secret; Vercel Cron sends it in the Authorization header
CRON_SECRET=

# --- OAuth bootstrap protection ---
# Anti-CSRF state for the /api/auth/callback seed route. Floor: a shared random
# string you also pass as `state` when starting the OAuth flow. Real fix: per-flow
# random state in a signed cookie.
OAUTH_STATE=

# --- Optional: alerting on token-refresh failure ---
# e.g. a Telegram bot token + chat id, or a webhook URL
ALERT_WEBHOOK_URL=
